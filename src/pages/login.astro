---
import BaseLayout from '../layouts/BaseLayout.astro';
import VaultSeal from '$lib/components/VaultSeal';
import { actions } from 'astro:actions';

if (Astro.locals.user?.id) {
	return Astro.redirect('/games');
}

const result = Astro.getActionResult(actions.login);

if (result?.data?.success) {
	return Astro.redirect('/games');
}

const notVerified = result?.data?.notVerified;
const invalidCredentials = result?.data?.invalidCredentials;

const inputClass =
	'px-3 rounded-vault h-9 w-full bg-vault-surface-raised border border-vault-border text-vault-text placeholder:text-vault-muted/60 focus:outline-none focus:ring-2 focus:ring-vault-accent focus:border-vault-accent transition-colors duration-150';
const labelClass = 'text-xs font-mono uppercase tracking-wide text-vault-muted';
---

<BaseLayout title="Login">
	<div class="flex h-full items-center justify-center">
		<form
			method="POST"
			action={actions.login}
			class="relative overflow-hidden w-full h-full lg:w-96 xl:w-[26rem] lg:h-auto rounded-vault shadow-vault bg-vault-surface border border-vault-border flex flex-col gap-y-3 p-6"
		>
			<VaultSeal className="absolute -right-8 -bottom-8 w-48 h-48 text-vault-accent opacity-[0.06] pointer-events-none" />
			<h2 class="relative text-center text-2xl font-display text-vault-text">Welcome back</h2>
			{notVerified && <p class="relative text-red-400 text-sm">Account not verified.</p>}
			{
				invalidCredentials && (
					<p class="relative text-red-400 text-sm">Invalid username or password.</p>
				)
			}
			<label class="relative h-16 flex flex-col gap-y-1">
				<span class={labelClass}>Username</span>
				<input name="username" required class={inputClass} />
			</label>
			<label class="relative h-16 flex flex-col gap-y-1">
				<span class={labelClass}>Password</span>
				<input name="password" type="password" required class={inputClass} />
			</label>
			<div class="relative mt-auto">
				<button
					type="submit"
					class="w-full bg-vault-accent text-vault-ink hover:bg-vault-accent/90 active:bg-vault-accent/80 font-semibold rounded-vault py-1.5 px-3 transition-colors duration-150 flex items-center gap-x-2 justify-center"
				>
					Login
				</button>
			</div>
		</form>
	</div>
</BaseLayout>
