---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameDashboard from '$lib/components/GameDashboard';
import { db } from '$lib/server/util/db';
import type { GameType, FoundryServiceEnvs } from '$lib/types/types';

if (!Astro.locals.user?.id) {
	return Astro.redirect('/login');
}

const games = await db
	.collection('games')
	.getFullList<GameType>({ filter: `owner_id = '${Astro.locals.user.id}' || owner_id = null` });

const activeGameRes = await fetch(
	`https://admin.salaraan.com/api/v1/services/${import.meta.env.FOUNDRY_SERVICE_ID}/envs`,
	{
		headers: {
			Authorization: `Bearer ${import.meta.env.COOLIFY_TOKEN}`
		}
	}
);
const activeGameData = (await activeGameRes.json()) as FoundryServiceEnvs[];
const currentWorld = activeGameData.find((e) => e.key === 'FOUNDRY_WORLD')?.value;
---

<BaseLayout title="Games">
	<GameDashboard client:load games={games} currentWorld={currentWorld} />
</BaseLayout>
