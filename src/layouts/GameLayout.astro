---
import { Icon } from '@iconify/react';
import BaseLayout from './BaseLayout.astro';
import SessionStatus from '$lib/components/SessionStatus';
import { db } from '$lib/server/util/db';
import type { GameType } from '$lib/types/types';

interface Props {
	title?: string;
}

const { title } = Astro.props;
const { game, id } = Astro.params;
const pathname = Astro.url.pathname;

const iconStyle = { fontSize: 20 };

const gameData = game
	? await db.collection('games').getFirstListItem<GameType>(`url = "${game}"`).catch(() => undefined)
	: undefined;

function navClass(active: boolean) {
	return `flex items-center gap-x-3 px-3 py-2 rounded-vault text-sm transition-colors duration-150 ${
		active
			? 'bg-vault-surface-raised text-vault-accent font-medium'
			: 'text-vault-muted hover:text-vault-text hover:bg-vault-surface-raised'
	}`;
}
---

<BaseLayout title={title}>
	<div class="flex h-full w-full">
		<nav class="w-56 shrink-0 flex flex-col border-r border-vault-border bg-vault-surface h-full py-4">
			<div class="px-4 pb-4 mb-2 border-b border-vault-border">
				<span class="font-display text-lg text-vault-text truncate block">
					{gameData?.title ?? 'Vault'}
				</span>
				<a href="/games" class="text-xs font-mono text-vault-muted hover:text-vault-accent">
					Switch campaign
				</a>
			</div>
			<ul class="flex flex-col gap-y-1 px-2">
				<li>
					<a href={`/${game}/images/1`} class={navClass(id === 'images')}>
						<Icon icon="ph:image" style={iconStyle} />
						<span>Images</span>
					</a>
				</li>
				<li>
					<a href={`/${game}/music/1`} class={navClass(id === 'music')}>
						<Icon icon="ph:music-notes" style={iconStyle} />
						<span>Music</span>
					</a>
				</li>
				<li>
					<a href={`/${game}/common`} class={navClass(!!pathname?.includes('common'))}>
						<Icon icon="ph:folder-open" style={iconStyle} />
						<span>Common</span>
					</a>
				</li>
				<li>
					<a href={`/${game}/search`} class={navClass(!!pathname?.endsWith('search'))}>
						<Icon icon="ph:magnifying-glass" style={iconStyle} />
						<span>Search</span>
					</a>
				</li>
				<li>
					<a href={`/${game}/api`} class={navClass(!!pathname?.endsWith('api'))}>
						<Icon icon="hugeicons:connect" style={iconStyle} />
						<span>API</span>
					</a>
				</li>
			</ul>
			<div class="mt-auto px-2">
				<a href="/api/auth/logout" class={navClass(!!pathname?.endsWith('search'))}>
					<Icon icon="ph:sign-out" style={iconStyle} />
					<span>Sign out</span>
				</a>
			</div>
		</nav>

		<div class="flex-1 flex flex-col overflow-hidden">
			<header class="flex items-center justify-between px-6 py-3 border-b border-vault-border shrink-0">
				<h1 class="font-display text-xl text-vault-text">{title}</h1>
				<SessionStatus client:load variant="compact" />
			</header>
			<main class="flex-1 overflow-y-auto px-6 py-4">
				<slot />
			</main>
		</div>
	</div>
</BaseLayout>
