---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Asset Browser' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
	</head>
	<body>
		<div class="w-screen h-screen bg-zinc-950 text-white text-base p-4">
			<slot />
		</div>
	</body>
</html>
