---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Vault' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
	</head>
	<body>
		<div class="w-screen h-screen bg-vault-ink text-vault-text font-sans text-base p-4">
			<slot />
		</div>
	</body>
</html>
